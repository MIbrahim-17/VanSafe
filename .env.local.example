# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# New-format publishable key (sb_publishable_...). Legacy anon key also works
# via NEXT_PUBLIC_SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Server-only secret key (sb_secret_...). Legacy service_role key also works
# via SUPABASE_SERVICE_ROLE_KEY. NEVER expose this to the browser.
SUPABASE_SECRET_KEY=sb_secret_xxx

# --- Google Gemini (optional; rule-based fallback used if absent) ---
GEMINI_API_KEY=your-gemini-api-key

# --- Meta WhatsApp Cloud API (optional; in-app simulator used if absent) ---
# From Meta App Dashboard -> WhatsApp -> API Setup.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# A token you choose; enter the same value in the webhook config in Meta.
WHATSAPP_VERIFY_TOKEN=
# Optional, defaults to v21.0
WHATSAPP_API_VERSION=v21.0
