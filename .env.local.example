# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# New-format publishable key (sb_publishable_...). Legacy anon key also works
# via NEXT_PUBLIC_SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Server-only secret key (sb_secret_...). Legacy service_role key also works
# via SUPABASE_SERVICE_ROLE_KEY. NEVER expose this to the browser.
SUPABASE_SECRET_KEY=sb_secret_xxx

# --- Google Gemini (optional; rule-based fallback used if absent) ---
GEMINI_API_KEY=your-gemini-api-key

# --- Twilio WhatsApp (optional; in-app simulator used if absent) ---
# From the Twilio Console.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your Twilio WhatsApp sender, e.g. the sandbox number whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=
# Optional: approved Content template SID (HX...) for proactive alerts. With it,
# alerts are sent as a template ({{1}} = the alert text); without it, free-form.
TWILIO_CONTENT_SID=
# Inbound webhook is signature-validated when TWILIO_AUTH_TOKEN is set.
# If the auto-reconstructed URL ever mismatches behind a proxy, either pin it:
#   TWILIO_WEBHOOK_URL=https://<your-tunnel>/api/whatsapp/webhook
# or disable validation:
#   TWILIO_VALIDATE_SIGNATURE=false
TWILIO_WEBHOOK_URL=
TWILIO_VALIDATE_SIGNATURE=
